#!/bin/bash
#SBATCH --job-name=flowarray
#SBATCH --output=logs/%x_%A_%a.out
#SBATCH --error=logs/%x_%A_%a.err
#SBATCH --partition=general
#SBATCH --chdir=/home/sophiapi/flow-manifold
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=4
#SBATCH --mem=16G
#SBATCH --time=08:00:00
#SBATCH --array=0-53%8    # 54 unique configs, at most 8 simultaneous

# Reads config path from configs/all_runs.txt (one path per line).
# Generated by: python scripts/launch_sweep.py

source ~/.bashrc
conda activate flowmanifold

mkdir -p logs

CONFIG=$(sed -n "$((SLURM_ARRAY_TASK_ID + 1))p" configs/all_runs.txt)

echo "Array task ${SLURM_ARRAY_TASK_ID}: ${CONFIG}"
python scripts/run_one_config.py --config "${CONFIG}"
